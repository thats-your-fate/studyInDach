generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model University {
  id                    String          @id
  name                  String
  location              String?
  state                 String?
  websiteUrl            String?
  duplicateStatus       String          @default("unique")
  canonicalUniversityId String?
  duplicateNotes        String?
  programs              DegreeProgram[]
  blogPostLinks         BlogPostUniversityLink[]

  @@index([name])
  @@index([duplicateStatus])
  @@index([canonicalUniversityId])
}

model DegreeProgram {
  id                      Int                        @id @default(autoincrement())
  slug                    String                     @unique
  programUrl              String                     @unique
  programName             String
  degreeLevel             String?
  academicDegree          String?
  subjectArea             String?
  languageOfInstruction   String?
  campusLocation          String?
  duration                String?
  ects                    String?
  startTerms              String?
  applicationDeadlines    String?
  admissionRequirements   String?
  tuitionOrFees           String?
  studyMode               String?
  restrictedAdmission     String?
  applicationUrl          String?
  contactEmail            String?
  summary                 String?
  heroImageUrl            String?
  studyField              String?
  secondaryStudyField     String?
  internationalStudentFit String?
  onlineOrOnCampus        String?
  fullTimeOrPartTime      String?
  applicationDifficulty   String?
  tuitionType             String?
  workExperienceRequired  String?
  metadataConfidence      String?
  image                   String?
  authorImage             String?
  reviewStatus            String                     @default("pending")
  isPublished             Boolean                    @default(true)
  isLikelyDegreeProgram   Boolean                    @default(true)
  qualityFlags            String?
  duplicateStatus         String                     @default("unique")
  canonicalProgramId      Int?
  duplicateNotes          String?
  universityId            String
  university              University                 @relation(fields: [universityId], references: [id], onDelete: Cascade)
  translations            DegreeProgramTranslation[]
  blogPostLinks           BlogPostProgramLink[]

  @@index([degreeLevel])
  @@index([studyField])
  @@index([subjectArea])
  @@index([reviewStatus])
  @@index([isPublished])
  @@index([isLikelyDegreeProgram])
  @@index([duplicateStatus])
  @@index([canonicalProgramId])
  @@index([universityId])
}

model DegreeProgramTranslation {
  id                    Int           @id @default(autoincrement())
  locale                String
  localizedProgramName  String
  subjectArea           String?
  languageOfInstruction String?
  campusLocation        String?
  duration              String?
  startTerms            String?
  applicationDeadlines  String?
  admissionRequirements String?
  tuitionOrFees         String?
  studyMode             String?
  restrictedAdmission   String?
  summary               String?
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String?
  searchIntentTags      String?
  careerOutcomes        String?
  skillsYouWillLearn    String?
  programHighlights     String?
  targetAudience        String?
  bestFor               String?
  metadataNotes         String?
  programId             Int
  program               DegreeProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, locale])
  @@index([locale])
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status                String  @default("new")
  name                  String?
  email                 String
  countryOfResidence    String?
  preferredStudyCountry String?
  message               String

  programId              Int?
  programNameSnapshot    String?
  universityNameSnapshot String?
  programUrlSnapshot     String?

  locale      String?
  sourcePath  String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  landingPath String?
  adminNotes  String?

  @@index([status])
  @@index([email])
  @@index([programId])
  @@index([locale])
  @@index([sourcePath])
  @@index([landingPath])
  @@index([createdAt])
}

model BlogPost {
  id              Int              @id @default(autoincrement())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  publishedAt     DateTime?
  status          String           @default("draft")
  type            String           @default("guide")
  authorName      String?          @default("Yaroslav Vynnychuk")
  coverImageUrl   String?
  coverImageAlt   String?
  featured        Boolean          @default(false)
  noindex         Boolean          @default(false)
  translationKey  String           @unique
  canonicalPostId Int?
  canonicalPost   BlogPost?        @relation("CanonicalBlogPost", fields: [canonicalPostId], references: [id])
  duplicates      BlogPost[]       @relation("CanonicalBlogPost")
  categoryId      Int?
  category        BlogCategory?    @relation(fields: [categoryId], references: [id])
  translations    BlogPostTranslation[]
  tags            BlogPostTag[]
  programLinks    BlogPostProgramLink[]
  universityLinks BlogPostUniversityLink[]
  filterBlocks    BlogPostFilterBlock[]
  faqs            BlogPostFaq[]

  @@index([status, publishedAt])
  @@index([type])
  @@index([categoryId])
}

model BlogPostTranslation {
  id              Int       @id @default(autoincrement())
  postId          Int
  post            BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale          String
  slug            String
  title           String
  excerpt         String?
  contentMd       String
  contentHtml     String?
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  ogTitle         String?
  ogDescription   String?
  ogImageUrl      String?
  readingMinutes  Int?
  tableOfContents String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([locale, slug])
  @@unique([postId, locale])
  @@index([locale])
}

model BlogCategory {
  id           Int                       @id @default(autoincrement())
  key          String                    @unique
  sortOrder    Int                       @default(0)
  posts        BlogPost[]
  translations BlogCategoryTranslation[]
}

model BlogCategoryTranslation {
  id          Int          @id @default(autoincrement())
  categoryId  Int
  category    BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale      String
  name        String
  slug        String
  description String?

  @@unique([locale, slug])
  @@unique([categoryId, locale])
}

model BlogTag {
  id           Int                  @id @default(autoincrement())
  key          String               @unique
  translations BlogTagTranslation[]
  posts        BlogPostTag[]
}

model BlogTagTranslation {
  id       Int     @id @default(autoincrement())
  tagId    Int
  tag      BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  locale   String
  name     String
  slug     String

  @@unique([locale, slug])
  @@unique([tagId, locale])
}

model BlogPostTag {
  postId Int
  tagId  Int
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model BlogPostProgramLink {
  id        Int           @id @default(autoincrement())
  postId    Int
  programId Int
  sortOrder Int           @default(0)
  label     String?
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  program   DegreeProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([programId])
}

model BlogPostUniversityLink {
  id           Int        @id @default(autoincrement())
  postId       Int
  universityId String
  sortOrder    Int        @default(0)
  label        String?
  post         BlogPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([universityId])
}

model BlogPostFilterBlock {
  id          Int      @id @default(autoincrement())
  postId      Int
  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  key         String?
  locale      String?
  title       String
  description String?
  filterJson  String
  limit       Int      @default(8)
  sortOrder   Int      @default(0)
  ctaLabel    String?
  ctaHref     String?
  displayMode String   @default("cards")
  enabled     Boolean  @default(true)

  @@index([postId])
  @@index([key])
  @@index([enabled])
}

model BlogPostFaq {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale    String?
  question  String
  answer    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([locale])
}
