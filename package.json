{
  "name": "study-in-dach",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node server.js",
    "start:passenger": "NODE_ENV=production node server.js",
    "plesk:build": "prisma db push && prisma generate && next build",
    "lint": "next lint",
    "seo:check": "node scripts/seo-check.mjs",
    "localized-url:check": "node scripts/check-localized-url-regressions.cjs",
    "quality:flag": "node scripts/flag-non-degree-programs.cjs",
    "quality:flag:dry": "node scripts/flag-non-degree-programs.cjs --dry-run",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:dach": "node prisma/seed.cjs --dataset dach",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "aos": "^2.3.4",
    "bootstrap": "^5.3.3",
    "gsap": "^3.12.7",
    "isotope-layout": "^3.0.6",
    "next": "^14.2.1",
    "react": "^18",
    "react-dom": "^18",
    "react-modal-video": "^2.0.2",
    "split-text": "^1.0.0",
    "swiper": "^11.2.5",
    "wowjs": "^1.1.3"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@types/bootstrap": "^5.2.10",
    "@types/isotope-layout": "^3.0.14",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-modal-video": "^1.2.3",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "prisma": "^5.22.0",
    "typescript": "^5"
  }
}
