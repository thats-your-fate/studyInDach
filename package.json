{
  "name": "study-in-dach",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "node scripts/with-env.cjs -- \"next dev\"",
    "build": "node scripts/with-env.cjs -- \"prisma generate && next build\"",
    "start": "node scripts/with-env.cjs -- \"node server.js\"",
    "start:passenger": "NODE_ENV=production node scripts/with-env.cjs -- \"node server.js\"",
    "plesk:build": "node scripts/with-env.cjs -- \"prisma db push && prisma generate && next build\"",
    "lint": "next lint",
    "seo:check": "node scripts/with-env.cjs -- \"node scripts/seo-check.mjs\"",
    "localized-url:check": "node scripts/with-env.cjs -- \"node scripts/check-localized-url-regressions.cjs\"",
    "quality:flag": "node scripts/with-env.cjs -- \"node scripts/flag-non-degree-programs.cjs\"",
    "quality:flag:dry": "node scripts/with-env.cjs -- \"node scripts/flag-non-degree-programs.cjs --dry-run\"",
    "db:migrate": "node scripts/with-env.cjs -- \"prisma migrate deploy\"",
    "db:migrate:status": "node scripts/with-env.cjs -- \"prisma migrate status\"",
    "db:push": "node scripts/with-env.cjs -- \"prisma db push\"",
    "db:seed": "node scripts/with-env.cjs -- \"prisma db seed\"",
    "db:seed:dach": "node scripts/with-env.cjs -- \"node prisma/seed.cjs --dataset dach\"",
    "postinstall": "node scripts/with-env.cjs -- \"prisma generate\""
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "aos": "^2.3.4",
    "bootstrap": "^5.3.3",
    "gsap": "^3.12.7",
    "isotope-layout": "^3.0.6",
    "next": "^14.2.1",
    "react": "^18",
    "react-dom": "^18",
    "react-modal-video": "^2.0.2",
    "split-text": "^1.0.0",
    "swiper": "^11.2.5",
    "wowjs": "^1.1.3"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@types/bootstrap": "^5.2.10",
    "@types/isotope-layout": "^3.0.14",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-modal-video": "^1.2.3",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "prisma": "^5.22.0",
    "typescript": "^5"
  }
}
